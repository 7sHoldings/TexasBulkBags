# Copy to .env.local (local) or set in Vercel → Settings → Environment Variables.
# The app runs without these, but quote/order/contact emails only send when
# RESEND_API_KEY is set (otherwise leads are written to the server logs).

# Inbox that receives quote / order / contact leads.
LEAD_INBOX=texasbulkbags@gmail.com

# --- Option A: SMTP (e.g. Namecheap Private Email) ---
# If these are set, mail is sent via SMTP. See docs/EMAIL-SETUP.md.
# Namecheap Private Email: host=mail.privateemail.com, port=465.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=          # full mailbox address, e.g. info@texasbulkbags.com
SMTP_PASS=          # that mailbox's password

# --- Option B: Resend (used only if SMTP is not configured) ---
# Free key at https://resend.com.
RESEND_API_KEY=

# From address. For SMTP this must be your authenticated mailbox
# (e.g. info@texasbulkbags.com). For Resend's test sender, leave default.
EMAIL_FROM="Texas Bulk Bags <onboarding@resend.dev>"

# --- Analytics ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Loads only when set.
NEXT_PUBLIC_GA_ID=
