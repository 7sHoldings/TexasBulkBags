# Copy to .env.local (local) or set in Vercel → Settings → Environment Variables.
# The app runs without these, but quote/order/contact emails only send when
# RESEND_API_KEY is set (otherwise leads are written to the server logs).

# --- Email lead delivery (Resend) ---
# Get a free key at https://resend.com. See docs/EMAIL-SETUP.md for the
# 5-minute setup. Without it, submissions are logged, not emailed.
RESEND_API_KEY=

# Inbox that receives quote / order / contact leads.
LEAD_INBOX=texasbulkbags@gmail.com

# Verified sender. The default works for testing and can send ONLY to the
# email you registered your Resend account with. To send from your own
# domain (e.g. quotes@texasbulkbags.com), verify the domain in Resend and
# set it here.
EMAIL_FROM="Texas Bulk Bags <onboarding@resend.dev>"

# --- Analytics ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Loads only when set.
NEXT_PUBLIC_GA_ID=
