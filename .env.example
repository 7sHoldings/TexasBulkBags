# Copy to .env.local and fill in. All are optional — the app runs without them.

# --- Email lead delivery (Resend) ---
# When set, quote/order/contact submissions are emailed to LEAD_INBOX.
# Without it, submissions are logged to the server console instead.
RESEND_API_KEY=
# Inbox that receives leads (defaults to info@texasbulkbags.com)
LEAD_INBOX=info@texasbulkbags.com
# Verified sender (defaults to Resend's onboarding sender for testing)
EMAIL_FROM="Texas Bulk Bags <onboarding@resend.dev>"

# --- Analytics ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Analytics load only when set.
NEXT_PUBLIC_GA_ID=
